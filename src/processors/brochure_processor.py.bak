import re
from src.ocr.extractor import OCRExtractor


class BrochureProcessor:

    def __init__(self):

        self.ocr = OCRExtractor()

    ###########################################################

    def process(self, brochure_path):

        text = self.ocr.extract(brochure_path)

        info = {

            "brochure": brochure_path,

            "raw_text": text,

            "tournament_name": self.find_tournament(text),

            "venue": self.find_venue(text),

            "dates": self.find_dates(text),

            "entry_fee": self.find_entry_fee(text),

            "prize_fund": self.find_prize(text),

            "contact": self.find_contact(text),

            "email": self.find_email(text),

            "website": self.find_website(text),

            "categories": self.find_categories(text)

        }

        return info

    ###########################################################

    def find_tournament(self, text):

        lines = text.splitlines()

        for line in lines:

            if "CHESS" in line.upper():

                return line.strip()

        return ""

    ###########################################################

    def find_dates(self, text):

        pattern = r"\d{1,2}[/-]\d{1,2}[/-]\d{2,4}"

        return re.findall(pattern, text)

    ###########################################################

    def find_contact(self, text):

        pattern = r"(?:\+91[- ]?)?[6-9]\d{9}"

        result = re.findall(pattern, text)

        return result

    ###########################################################

    def find_email(self, text):

        pattern = r"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}"

        result = re.findall(pattern, text)

        return result

    ###########################################################

    def find_website(self, text):

        pattern = r"(https?://\S+|www\.\S+)"

        result = re.findall(pattern, text)

        return result

    ###########################################################

    def find_entry_fee(self, text):

        pattern = r"(?:Entry Fee|Registration Fee|Fee)\D{0,10}₹?\s?([\d,]+)"

        match = re.search(pattern, text, re.IGNORECASE)

        if match:

            return match.group(1)

        return ""

    ###########################################################

    def find_prize(self, text):

        pattern = r"(?:Prize Fund|Total Prize|Prize)\D{0,10}₹?\s?([\d,]+)"

        match = re.search(pattern, text, re.IGNORECASE)

        if match:

            return match.group(1)

        return ""

    ###########################################################

    def find_categories(self, text):

        categories = []

        possible = [

            "U7",

            "U9",

            "U11",

            "U13",

            "U15",

            "U17",

            "U19",

            "Open",

            "Women"

        ]

        upper = text.upper()

        for cat in possible:

            if cat.upper() in upper:

                categories.append(cat)

        return categories

    ###########################################################

    def find_venue(self, text):

        lines = text.splitlines()

        keywords = [

            "VENUE",

            "LOCATION",

            "ADDRESS"

        ]

        for i, line in enumerate(lines):

            for key in keywords:

                if key in line.upper():

                    if i + 1 < len(lines):

                        return lines[i + 1].strip()

        return ""
